generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  subdomain String   @unique
  plan      String   @default("starter")
  createdAt DateTime @default(now())

  users     User[]
  products  Product[]
  orders    Order[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("owner")
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Float
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
}

model Order {
  id        String   @id @default(uuid())
  total     Float
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
}
